#!/bin/bash

# ==============================================================================
# Better Laravel React Installer - Single-File CLI
# ==============================================================================
# Version: 2.0.0
# A minimal, modern, and robust installer for the Better Laravel React starter kit.
# Supports bash, zsh, and fish shells with clean TUI-based interactive experience.
# ==============================================================================

set -e

# ==============================================================================
# CONFIGURATION
# ==============================================================================

readonly REPO_URL="https://github.com/MAHMETT/better-laravel-react.git"

# Branch configuration: array of {title, branch}
readonly -a BRANCH_TITLES=("main" "development" "+ visitor management")
readonly -a BRANCH_NAMES=("main" "development" "analytics-visitor")
readonly DEFAULT_BRANCH="main"

# Runtime configuration
readonly -a RUNTIMES=("npm" "pnpm" "yarn" "bun")
readonly DEFAULT_RUNTIME="npm"

# Folders to remove during cleanup
readonly -a CLEANUP_FOLDERS=("docs" ".agents" ".claude" ".codex" ".qwen" ".git" ".github")

# Files to remove during cleanup
readonly -a CLEANUP_FILES=(".bunrc" "bun.lock" ".mcp.json" "qwen.json" "mcp.json" "AGENTS.md" "CLAUDE.md" "QWEN.md" "boost.json" "_ide_helper.php" "opencode.json")

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly CYAN='\033[0;36m'
readonly GRAY='\033[0;90m'
readonly BOLD='\033[1m'
readonly DIM='\033[2m'
readonly NC='\033[0m'

# State variables
PROJECT_NAME=""
SELECTED_BRANCH=""
SELECTED_RUNTIME=""
INSTALL_COMPOSER="true"
INSTALL_NODE="true"
INSTALLATION_STARTED="false"
INSTALLATION_COMPLETED="false"

# ==============================================================================
# TUI OUTPUT FUNCTIONS
# ==============================================================================

print_banner() {
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}${CYAN}   Better Laravel React Installer${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

print_section() {
    echo ""
    echo -e "${BOLD}${CYAN}━━━ $1 ${NC}"
    echo ""
}

print_step() {
    echo -e "${DIM}[$1]${NC} $2"
}

print_success() {
    echo -e "${GREEN}  ✔${NC} $1"
}

print_error() {
    echo -e "${RED}  ✖${NC} ${RED}$1${NC}"
}

print_warning() {
    echo -e "${YELLOW}  ⚠${NC} $1"
}

print_info() {
    echo -e "${CYAN}  ℹ${NC} $1"
}

print_divider() {
    echo -e "${GRAY}────────────────────────────────────────${NC}"
}

# ==============================================================================
# ERROR HANDLING
# ==============================================================================

handle_interrupt() {
    echo ""
    print_divider
    echo ""
    
    if [ "$INSTALLATION_STARTED" = "true" ] && [ "$INSTALLATION_COMPLETED" != "true" ]; then
        print_warning "Installation interrupted"
        
        if [ -n "$PROJECT_NAME" ] && [ -d "$PROJECT_NAME" ]; then
            echo ""
            echo -e "${DIM}  Partial installation detected:${NC}"
            echo -e "${DIM}  Project directory '$PROJECT_NAME' was created${NC}"
            echo ""
            echo "  Options:"
            echo ""
            echo "  1) Continue manually:"
            echo -e "     ${GRAY}cd $PROJECT_NAME${NC}"
            echo ""
            echo "  2) Remove and restart:"
            echo -e "     ${GRAY}rm -rf $PROJECT_NAME${NC}"
            echo -e "     ${GRAY}better-laravel new${NC}"
            echo ""
        fi
    else
        print_info "No changes were made"
    fi
    
    echo -e "${GRAY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 130
}

trap 'handle_interrupt' INT TERM

# ==============================================================================
# STAGE 1: DEPENDENCY CHECKING
# ==============================================================================

check_dependencies() {
    local missing=()
    local has_node_runtime=false
    
    # Check PHP (required)
    if ! command -v php >/dev/null 2>&1; then
        missing+=("php")
    fi
    
    # Check Composer (required)
    if ! command -v composer >/dev/null 2>&1; then
        missing+=("composer")
    fi
    
    # Check Node runtime (at least one required)
    for runtime in "${RUNTIMES[@]}"; do
        if command -v "$runtime" >/dev/null 2>&1; then
            has_node_runtime=true
            break
        fi
    done
    
    if [ "$has_node_runtime" = false ]; then
        missing+=("npm OR pnpm OR yarn OR bun (at least one required)")
    fi
    
    # Report errors and exit if any dependencies are missing
    if [ ${#missing[@]} -gt 0 ]; then
        echo ""
        print_error "Missing dependency detected:"
        echo ""
        for dep in "${missing[@]}"; do
            echo -e "  ${RED}•${NC} $dep"
        done
        echo ""
        print_error "Installation cannot continue."
        echo ""
        exit 1
    fi
    
    # All dependencies satisfied - continue silently (no success message)
}

# ==============================================================================
# STAGE 2: USER CONFIGURATION FIELDS
# ==============================================================================

get_project_name() {
    print_section "Project Configuration"
    
    while true; do
        echo -ne "  ${CYAN}Enter project name${NC}: "
        read -r PROJECT_NAME
        
        if validate_project_name "$PROJECT_NAME"; then
            break
        else
            echo ""
            print_error "Invalid project name"
            echo ""
            echo "  Requirements:"
            echo "  • Maximum 200 characters"
            echo "  • Must be lowercase"
            echo "  • No spaces (use '-' instead)"
            echo "  • Allowed: a-z, 0-9, hyphen (-), underscore (_)"
            echo ""
        fi
    done
}

validate_project_name() {
    local name="$1"
    
    # Check if empty
    [ -z "$name" ] && return 1
    
    # Check length
    [ ${#name} -gt 200 ] && return 1
    
    # Check if lowercase (no uppercase letters)
    [ "$name" != "${name,,}" ] && return 1
    
    # Check for spaces
    [[ "$name" =~ [[:space:]] ]] && return 1
    
    # Check allowed characters (a-z, 0-9, -, _)
    ! [[ "$name" =~ ^[a-z0-9_-]+$ ]] && return 1
    
    return 0
}

get_branch() {
    print_section "Branch Selection"
    
    echo -e "  ${GRAY}Available branches:${NC}"
    echo ""
    
    for i in "${!BRANCH_TITLES[@]}"; do
        local default_mark=""
        [ "${BRANCH_NAMES[$i]}" = "$DEFAULT_BRANCH" ] && default_mark=" ${GRAY}(default)${NC}"
        echo -e "  ${GREEN}$((i + 1))${NC}) ${BRANCH_TITLES[$i]}$default_mark"
    done
    
    echo ""
    
    while true; do
        echo -ne "  ${CYAN}Select branch${NC} [1-${#BRANCH_TITLES[@]}]: "
        read -r choice
        
        # Default to 1 if empty
        [ -z "$choice" ] && choice=1
        
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#BRANCH_TITLES[@]}" ]; then
            SELECTED_BRANCH="${BRANCH_NAMES[$((choice - 1))]}"
            break
        else
            print_error "Invalid selection"
            echo ""
        fi
    done
}

get_runtime() {
    print_section "Runtime Selection"
    
    echo -e "  ${GRAY}Available runtimes:${NC}"
    echo ""
    
    for i in "${!RUNTIMES[@]}"; do
        local default_mark=""
        [ "${RUNTIMES[$i]}" = "$DEFAULT_RUNTIME" ] && default_mark=" ${GRAY}(default)${NC}"
        echo -e "  ${GREEN}$((i + 1))${NC}) ${RUNTIMES[$i]}$default_mark"
    done
    
    echo ""
    
    while true; do
        echo -ne "  ${CYAN}Select runtime${NC} [1-${#RUNTIMES[@]}]: "
        read -r choice
        
        # Default to 1 (npm) if empty
        [ -z "$choice" ] && choice=1
        
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#RUNTIMES[@]}" ]; then
            SELECTED_RUNTIME="${RUNTIMES[$((choice - 1))]}"
            break
        else
            print_error "Invalid selection"
            echo ""
        fi
    done
}

get_install_options() {
    print_section "Package Installation"
    
    echo -e "  ${GRAY}Select packages to install:${NC}"
    echo ""
    echo -e "  ${GREEN}1${NC}) Composer dependencies ${GRAY}(default: yes)${NC}"
    echo -e "  ${GREEN}2${NC}) Node dependencies ${GRAY}(default: yes)${NC}"
    echo -e "  ${GREEN}3${NC}) Both"
    echo -e "  ${GREEN}4${NC}) None"
    echo ""
    
    while true; do
        echo -ne "  ${CYAN}Select option${NC} [1-4]: "
        read -r choice
        
        # Default to 3 (both) if empty
        [ -z "$choice" ] && choice=3
        
        case "$choice" in
            1)
                INSTALL_COMPOSER="true"
                INSTALL_NODE="false"
                break
                ;;
            2)
                INSTALL_COMPOSER="false"
                INSTALL_NODE="true"
                break
                ;;
            3)
                INSTALL_COMPOSER="true"
                INSTALL_NODE="true"
                break
                ;;
            4)
                INSTALL_COMPOSER="false"
                INSTALL_NODE="false"
                break
                ;;
            *)
                print_error "Invalid selection"
                echo ""
                ;;
        esac
    done
}

confirm_installation() {
    print_section "Installation Summary"
    
    echo -e "  ${GRAY}Project:${NC}     ${BOLD}$PROJECT_NAME${NC}"
    echo -e "  ${GRAY}Branch:${NC}      ${BOLD}$SELECTED_BRANCH${NC}"
    echo -e "  ${GRAY}Runtime:${NC}     ${BOLD}$SELECTED_RUNTIME${NC}"
    
    local install_summary=""
    if [ "$INSTALL_COMPOSER" = "true" ] && [ "$INSTALL_NODE" = "true" ]; then
        install_summary="Composer + Node dependencies"
    elif [ "$INSTALL_COMPOSER" = "true" ]; then
        install_summary="Composer dependencies only"
    elif [ "$INSTALL_NODE" = "true" ]; then
        install_summary="Node dependencies only"
    else
        install_summary="Skip dependency installation"
    fi
    
    echo -e "  ${GRAY}Install:${NC}     ${BOLD}$install_summary${NC}"
    echo ""
    echo -ne "  ${CYAN}Proceed with installation?${NC} [Y/n]: "
    read -r confirm
    
    if [[ "$confirm" =~ ^[Nn]$ ]]; then
        echo ""
        print_warning "Installation cancelled"
        echo ""
        exit 0
    fi
}

# ==============================================================================
# STAGE 3: MAIN INSTALLATION PROCESS
# ==============================================================================

clone_repository() {
    print_step "1" "Cloning repository..."
    
    # Check if directory already exists
    if [ -d "$PROJECT_NAME" ]; then
        echo ""
        print_error "Directory '$PROJECT_NAME' already exists"
        print_error "Please remove it or choose a different project name"
        echo ""
        exit 1
    fi
    
    # Clone repository
    if ! git clone "$REPO_URL" "$PROJECT_NAME" >/dev/null 2>&1; then
        echo ""
        print_error "Failed to clone repository"
        print_error "Check your internet connection and try again"
        echo ""
        exit 1
    fi
    
    print_success "Repository cloned to '$PROJECT_NAME'"
}

checkout_branch() {
    print_step "3" "Switching to branch '$SELECTED_BRANCH'..."
    
    if ! git checkout "$SELECTED_BRANCH" >/dev/null 2>&1; then
        echo ""
        print_error "Failed to checkout branch '$SELECTED_BRANCH'"
        echo ""
        exit 1
    fi
    
    print_success "Switched to branch '$SELECTED_BRANCH'"
}

cleanup_files() {
    print_step "4" "Cleaning unnecessary files..."
    
    local count=0
    
    # Remove folders
    for folder in "${CLEANUP_FOLDERS[@]}"; do
        if [ -d "$folder" ]; then
            rm -rf "$folder"
            count=$((count + 1))
        fi
    done
    
    # Remove files
    for file in "${CLEANUP_FILES[@]}"; do
        if [ -f "$file" ]; then
            rm -f "$file"
            count=$((count + 1))
        fi
    done
    
    print_success "Removed $count file(s)/folder(s)"
}

setup_environment() {
    print_step "5" "Preparing environment file..."
    
    if [ ! -f ".env.example" ]; then
        echo ""
        print_error ".env.example not found"
        print_error "Cannot create environment file"
        echo ""
        exit 1
    fi
    
    if ! cp ".env.example" ".env"; then
        echo ""
        print_error "Failed to create .env file"
        echo ""
        exit 1
    fi
    
    print_success ".env created"
}

install_dependencies() {
    if [ "$INSTALL_COMPOSER" = "false" ] && [ "$INSTALL_NODE" = "false" ]; then
        print_step "6" "Skipping dependency installation..."
        print_success "Dependency installation skipped"
        return
    fi
    
    print_step "6" "Installing dependencies..."
    
    # Install Composer dependencies
    if [ "$INSTALL_COMPOSER" = "true" ]; then
        if ! composer install --quiet 2>/dev/null; then
            echo ""
            print_error "Failed to install Composer dependencies"
            echo ""
            exit 1
        fi
        print_success "Composer dependencies installed"
    fi
    
    # Install Node dependencies based on selected runtime
    if [ "$INSTALL_NODE" = "true" ]; then
        local install_cmd=""
        case "$SELECTED_RUNTIME" in
            npm)  install_cmd="npm install" ;;
            pnpm) install_cmd="pnpm install" ;;
            yarn) install_cmd="yarn install" ;;
            bun)  install_cmd="bun install" ;;
        esac
        
        if ! $install_cmd >/dev/null 2>&1; then
            echo ""
            print_error "Failed to install Node dependencies"
            echo ""
            exit 1
        fi
        print_success "Node dependencies installed ($SELECTED_RUNTIME)"
    fi
}

print_completion() {
    echo ""
    print_section "Installation Complete"
    
    print_success "Installation completed successfully!"
    echo ""
    echo -e "  ${GRAY}Project:${NC}  ${BOLD}$PROJECT_NAME${NC}"
    echo -e "  ${GRAY}Branch:${NC}   ${BOLD}$SELECTED_BRANCH${NC}"
    echo -e "  ${GRAY}Runtime:${NC}  ${BOLD}$SELECTED_RUNTIME${NC}"
    echo ""
    echo -e "  ${GRAY}Next steps:${NC}"
    echo -e "     ${CYAN}cd $PROJECT_NAME${NC}"
    echo -e "     ${CYAN}php artisan serve${NC}"
    echo ""
    echo -e "  ${CYAN}Happy coding!${NC}"
    echo ""
    
    INSTALLATION_COMPLETED="true"
}

# ==============================================================================
# CLI PARSING
# ==============================================================================

show_help() {
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}${CYAN}   Better Laravel React Installer${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${BOLD}USAGE${NC}"
    echo -e "  better-laravel new"
    echo -e "  better-laravel update"
    echo ""
    echo -e "${BOLD}COMMANDS${NC}"
    echo -e "  new               Start a new Laravel + React project"
    echo -e "  update            Update the installer to the latest version"
    echo ""
    echo -e "${BOLD}GENERAL${NC}"
    echo -e "  --help, -h        Show this help message"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo -e "  ${GRAY}better-laravel new${NC}"
    echo -e "  ${GRAY}better-laravel update${NC}"
    echo ""
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --help|-h) show_help; exit 0 ;;
            *) echo -e "${RED}Unknown option: $1${NC}"; show_help; exit 1 ;;
        esac
    done
}

run_interactive() {
    # Stage 2: User Configuration Fields
    get_project_name
    get_branch
    get_runtime
    get_install_options
    confirm_installation
}

run_installation() {
    INSTALLATION_STARTED="true"
    
    # Stage 3: Main Installation Process
    clone_repository
    enter_project_directory
    checkout_branch
    cleanup_files
    setup_environment
    install_dependencies
    
    print_completion
}

enter_project_directory() {
    print_step "2" "Entering project directory..."
    
    if ! cd "$PROJECT_NAME" 2>/dev/null; then
        echo ""
        print_error "Failed to enter project directory"
        echo ""
        exit 1
    fi
    
    print_success "Changed to project directory"
}

# ==============================================================================
# UPDATE COMMAND
# ==============================================================================

get_current_version() {
    # Extract version from script comments or return "unknown"
    local version_line
    version_line=$(grep -m1 "^# Version:" "$1" 2>/dev/null || echo "")
    if [ -n "$version_line" ]; then
        echo "${version_line#*: }"
    else
        echo "unknown"
    fi
}

run_update() {
    print_banner
    print_section "Update Installer"
    
    local install_dir=""
    local script_path=""
    
    # Step 1: Detect installation location
    print_step "1" "4" "Detecting installation..."
    
    if [ -f "/usr/local/bin/better-laravel" ]; then
        install_dir="/usr/local/bin"
        script_path="/usr/local/bin/better-laravel"
    elif [ -f "$HOME/.local/bin/better-laravel" ]; then
        install_dir="$HOME/.local/bin"
        script_path="$HOME/.local/bin/better-laravel"
    elif [ -n "$INSTALL_DIR" ] && [ -f "$INSTALL_DIR/better-laravel" ]; then
        install_dir="$INSTALL_DIR"
        script_path="$INSTALL_DIR/better-laravel"
    else
        script_path=$(command -v better-laravel 2>/dev/null)
        if [ -n "$script_path" ]; then
            install_dir=$(dirname "$script_path")
        else
            print_error "Could not determine installer location"
            print_error "Please reinstall manually"
            echo ""
            exit 1
        fi
    fi
    
    print_success "Found at: ${GRAY}$script_path${NC}"
    
    # Step 2: Check current version
    print_step "2" "4" "Checking current version..."
    
    local current_version
    current_version=$(get_current_version "$script_path")
    print_info "Current version: ${GRAY}$current_version${NC}"
    
    # Step 3: Download latest version
    print_step "3" "4" "Downloading latest version..."
    
    local temp_file
    temp_file=$(mktemp)
    
    if command -v curl >/dev/null 2>&1; then
        if ! curl -fsSL -o "$temp_file" "https://raw.githubusercontent.com/MAHMETT/better-laravel-react-installer/refs/heads/main/better-laravel" 2>/dev/null; then
            print_error "Failed to download latest version"
            print_error "Check your internet connection"
            echo ""
            exit 1
        fi
    elif command -v wget >/dev/null 2>&1; then
        if ! wget -q -O "$temp_file" "https://raw.githubusercontent.com/MAHMETT/better-laravel-react-installer/refs/heads/main/better-laravel"; then
            print_error "Failed to download latest version"
            print_error "Check your internet connection"
            echo ""
            exit 1
        fi
    else
        print_error "curl or wget is required"
        echo ""
        exit 1
    fi
    
    print_success "Latest version downloaded"
    
    # Step 4: Install update
    print_step "4" "4" "Installing update..."
    
    chmod +x "$temp_file"
    
    local update_required=false
    if [ -w "$install_dir" ]; then
        if mv "$temp_file" "$script_path" 2>/dev/null; then
            update_required=true
        fi
    elif command -v sudo >/dev/null 2>&1; then
        print_info "Sudo privileges required for installation"
        if sudo mv "$temp_file" "$script_path" 2>/dev/null; then
            update_required=true
        fi
    fi
    
    if [ "$update_required" = false ]; then
        print_error "Failed to install update"
        print_error "Cannot write to $install_dir"
        echo ""
        exit 1
    fi
    
    print_success "Update installed successfully"
    
    # Completion
    echo ""
    print_section "Update Complete"
    
    print_success "Installer updated to the latest version!"
    echo ""
    echo -e "${GRAY}  Run ${CYAN}better-laravel --help${GRAY} to see what's new${NC}"
    echo ""
    echo -e "${GRAY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

# ==============================================================================
# MAIN
# ==============================================================================

main() {
    local cmd="${1:-}"
    shift || true
    
    parse_args "$@"
    
    case "$cmd" in
        new)
            print_banner
            
            # Stage 1: Dependency Checking
            check_dependencies
            
            # Stage 2: User Configuration Fields
            run_interactive
            
            # Stage 3: Main Installation Process
            run_installation
            ;;
        update)
            run_update
            ;;
        help|--help|-h|"")
            show_help
            ;;
        *)
            echo -e "${RED}Unknown command: $cmd${NC}"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
