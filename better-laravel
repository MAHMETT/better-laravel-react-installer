#!/bin/bash

# ==============================================================================
# Better Laravel React Installer - Single-File CLI
# ==============================================================================
# A minimal, cross-platform installer for the Better Laravel React starter kit.
# Supports bash, zsh, and fish shells.
# ==============================================================================

set -e

# ==============================================================================
# CONFIGURATION
# ==============================================================================

readonly REPO_URL="https://github.com/MAHMETT/better-laravel-react.git"
readonly DEFAULT_BRANCH="main"
readonly DEFAULT_RUNTIME="npm"

# Branch options: "Display Title|branch-name"
readonly -a BRANCHES=(
    "main|main"
    "+ visitor management|visitor-management"
)

# Available runtimes
readonly -a RUNTIMES=("npm" "pnpm" "yarn" "bun")

# Files/folders to cleanup
readonly -a CLEANUP_FOLDERS=("docs" ".agents" ".claude" ".codex" ".qwen" ".git" ".github")
readonly -a CLEANUP_FILES=(".bunrc" "bun.lock" "mcp.json" "AGENTS.md" "CLAUDE.md" "QWEN.md" "boost.json" "_ide_helper.php" "opencode.json")

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly GRAY='\033[0;90m'
readonly BOLD='\033[1m'
readonly NC='\033[0m'

# State
PROJECT_NAME=""
SELECTED_BRANCH=""
SELECTED_RUNTIME=""
INSTALL_COMPOSER=true
INSTALL_NODE=true
CLI_MODE=false

# ==============================================================================
# TUI OUTPUT FUNCTIONS
# ==============================================================================

print_banner() {
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}${CYAN}   Better Laravel React Installer${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GRAY}   Interactive Laravel Starter Kit${NC}"
    echo ""
}

print_section() {
    echo ""
    echo -e "${GRAY}────────────────────────────────────────${NC}"
    echo -e "${BOLD}${CYAN} $1${NC}"
    echo -e "${GRAY}────────────────────────────────────────${NC}"
}

print_step() {
    echo -e "${GREEN}[STEP $1/$2]${NC} $3"
}

print_success() {
    echo -e "  ${GREEN}✔${NC} $1"
}

print_error() {
    echo -e "  ${RED}✖${NC} ${RED}$1${NC}"
}

print_warning() {
    echo -e "  ${YELLOW}⚠${NC} $1"
}

print_info() {
    echo -e "  ${CYAN}ℹ${NC} $1"
}

# ==============================================================================
# ERROR HANDLING
# ==============================================================================

INSTALLATION_STARTED="false"
INSTALLATION_COMPLETED="false"

handle_interrupt() {
    echo ""
    echo ""
    print_section "Installation Cancelled"
    echo ""
    
    if [ "$INSTALLATION_STARTED" = "true" ] && [ "$INSTALLATION_COMPLETED" != "true" ]; then
        print_warning "Installation interrupted"
        
        if [ -n "$PROJECT_NAME" ] && [ -d "$PROJECT_NAME" ]; then
            echo ""
            echo -e "  ${DIM}Partial installation detected:${RESET}"
            echo -e "  ${DIM}Project directory '$PROJECT_NAME' was created${RESET}"
            echo ""
            echo "  Options:"
            echo ""
            echo "  1) Continue manually:"
            echo -e "     ${GRAY}cd $PROJECT_NAME${NC}"
            echo ""
            echo "  2) Remove and restart:"
            echo -e "     ${GRAY}rm -rf $PROJECT_NAME${NC}"
            echo -e "     ${GRAY}better-laravel new${NC}"
            echo ""
        fi
    else
        print_info "No changes were made"
    fi
    
    echo ""
    echo -e "${GRAY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 130
}

trap 'handle_interrupt' INT TERM

# ==============================================================================
# DEPENDENCY CHECKING
# ==============================================================================

check_dependencies() {
    print_section "Checking Dependencies"
    
    local has_error=false
    local missing=()
    
    # Check PHP
    if command -v php >/dev/null 2>&1; then
        print_success "PHP: $(php -v 2>&1 | head -n 1)"
    else
        missing+=("php")
    fi
    
    # Check Composer
    if command -v composer >/dev/null 2>&1; then
        print_success "Composer: $(composer --version 2>&1)"
    else
        missing+=("composer")
    fi
    
    # Check Git
    if command -v git >/dev/null 2>&1; then
        print_success "Git: $(git --version 2>&1)"
    else
        missing+=("git")
    fi
    
    # Check Node runtime
    local found_runtimes=()
    for runtime in "${RUNTIMES[@]}"; do
        if command -v "$runtime" >/dev/null 2>&1; then
            found_runtimes+=("$runtime: $($runtime --version 2>&1 | head -n 1)")
        fi
    done
    
    if [ ${#found_runtimes[@]} -gt 0 ]; then
        print_success "Node Runtime: ${found_runtimes[*]}"
    else
        missing+=("npm OR pnpm OR yarn OR bun")
    fi
    
    echo ""
    
    if [ ${#missing[@]} -gt 0 ]; then
        print_error "Missing dependencies: ${missing[*]}"
        echo -e "  ${GRAY}Installation cannot continue${NC}"
        echo ""
        exit 1
    fi
    
    print_success "All dependencies satisfied!"
}

# ==============================================================================
# INPUT VALIDATION
# ==============================================================================

validate_project_name() {
    local name="$1"
    
    [ -z "$name" ] && return 1
    [ ${#name} -gt 200 ] && return 1
    [ "$name" != "${name,,}" ] && return 1
    [[ "$name" =~ [[:space:]] ]] && return 1
    ! [[ "$name" =~ ^[a-z0-9_-]+$ ]] && return 1
    
    return 0
}

# ==============================================================================
# USER INPUT - INTERACTIVE
# ==============================================================================

get_project_name() {
    print_section "Project Configuration"
    
    while true; do
        echo ""
        echo -ne "  ${CYAN}Enter project name${NC}: "
        read -r PROJECT_NAME
        
        if validate_project_name "$PROJECT_NAME"; then
            print_success "Project name: ${BOLD}$PROJECT_NAME${NC}"
            break
        else
            print_error "Invalid project name"
            echo ""
            echo "  Requirements:"
            echo "  • Maximum 200 characters"
            echo "  • Must be lowercase"
            echo "  • No spaces (use '-' instead)"
            echo "  • Allowed: a-z, 0-9, hyphen (-), underscore (_)"
            echo ""
        fi
    done
}

get_branch() {
    echo ""
    print_section "Branch Selection"
    echo ""
    echo -e "  ${GRAY}Available branches:${NC}"
    echo ""
    
    for i in "${!BRANCHES[@]}"; do
        IFS='|' read -r title branch_name <<< "${BRANCHES[$i]}"
        local default_mark=""
        [ "$branch_name" = "$DEFAULT_BRANCH" ] && default_mark=" ${GRAY}(default)${NC}"
        echo -e "  ${GREEN}$((i + 1))${NC}) $title$default_mark"
    done
    
    echo ""
    
    while true; do
        echo -ne "  ${CYAN}Select branch${NC} [1-${#BRANCHES[@]}]: "
        read -r choice
        
        [ -z "$choice" ] && choice=1
        
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#BRANCHES[@]}" ]; then
            IFS='|' read -r title branch_name <<< "${BRANCHES[$((choice - 1))]}"
            SELECTED_BRANCH="$branch_name"
            print_success "Branch: ${BOLD}$SELECTED_BRANCH${NC}"
            break
        else
            print_error "Invalid selection"
        fi
    done
}

get_runtime() {
    echo ""
    print_section "Runtime Selection"
    echo ""
    echo -e "  ${GRAY}Available runtimes:${NC}"
    echo ""
    
    for i in "${!RUNTIMES[@]}"; do
        local runtime="${RUNTIMES[$i]}"
        local status="${RED}not found${NC}"
        local default_mark=""
        
        command -v "$runtime" >/dev/null 2>&1 && status="${GREEN}available${NC}"
        [ "$runtime" = "$DEFAULT_RUNTIME" ] && default_mark=" ${GRAY}(default)${NC}"
        
        printf "  ${GREEN}%d${NC}) %-8s %s%s\n" $((i + 1)) "$runtime" "$status" "$default_mark"
    done
    
    echo ""
    
    while true; do
        echo -ne "  ${CYAN}Select runtime${NC} [1-${#RUNTIMES[@]}]: "
        read -r choice
        
        [ -z "$choice" ] && choice=1
        
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#RUNTIMES[@]}" ]; then
            SELECTED_RUNTIME="${RUNTIMES[$((choice - 1))]}"
            
            if command -v "$SELECTED_RUNTIME" >/dev/null 2>&1; then
                print_success "Runtime: ${BOLD}$SELECTED_RUNTIME${NC}"
                break
            else
                print_error "$SELECTED_RUNTIME is not available"
            fi
        else
            print_error "Invalid selection"
        fi
    done
}

get_auto_install() {
    echo ""
    print_section "Package Installation"
    echo ""
    echo "  Select packages to install:"
    echo ""
    echo -e "  ${GREEN}1${NC}) Both Composer and Node dependencies  ${GRAY}(default)${NC}"
    echo -e "  ${GREEN}2${NC}) Only Composer dependencies"
    echo -e "  ${GREEN}3${NC}) Only Node dependencies"
    echo -e "  ${GREEN}4${NC}) None (manual installation)"
    echo ""
    
    while true; do
        echo -ne "  ${CYAN}Select option${NC} [1-4]: "
        read -r choice
        
        [ -z "$choice" ] && choice=1
        
        case "$choice" in
            1) INSTALL_COMPOSER=true; INSTALL_NODE=true; print_success "Installing: ${BOLD}Composer + Node${NC}"; break ;;
            2) INSTALL_COMPOSER=true; INSTALL_NODE=false; print_success "Installing: ${BOLD}Composer only${NC}"; break ;;
            3) INSTALL_COMPOSER=false; INSTALL_NODE=true; print_success "Installing: ${BOLD}Node only${NC}"; break ;;
            4) INSTALL_COMPOSER=false; INSTALL_NODE=false; print_success "Installing: ${BOLD}None${NC}"; break ;;
            *) print_error "Invalid selection" ;;
        esac
    done
}

confirm_installation() {
    echo ""
    print_section "Installation Summary"
    echo ""
    echo -e "  ${GRAY}Project:${NC}     ${BOLD}$PROJECT_NAME${NC}"
    echo -e "  ${GRAY}Branch:${NC}      ${BOLD}$SELECTED_BRANCH${NC}"
    echo -e "  ${GRAY}Runtime:${NC}     ${BOLD}$SELECTED_RUNTIME${NC}"
    echo -e "  ${GRAY}Composer:${NC}    ${BOLD}$([ "$INSTALL_COMPOSER" = true ] && echo "Yes" || echo "No")${NC}"
    echo -e "  ${GRAY}Node:${NC}        ${BOLD}$([ "$INSTALL_NODE" = true ] && echo "Yes ($SELECTED_RUNTIME)" || echo "No")${NC}"
    echo ""
    echo -ne "  ${CYAN}Proceed with installation?${NC} [y/N]: "
    read -r confirm
    
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        print_success "Starting installation..."
    else
        echo ""
        print_warning "Installation cancelled"
        echo ""
        exit 0
    fi
}

# ==============================================================================
# INSTALLATION WORKFLOW
# ==============================================================================

clone_repository() {
    print_step "1" "6" "Cloning repository..."
    
    if git clone "$REPO_URL" "$PROJECT_NAME" >/dev/null 2>&1; then
        print_success "Repository cloned to '${BOLD}$PROJECT_NAME${NC}'"
    else
        echo -e "\n${RED}Failed to clone repository${NC}"
        exit 1
    fi
}

enter_project_directory() {
    print_step "2" "6" "Entering project directory..."
    
    if cd "$PROJECT_NAME" 2>/dev/null; then
        print_success "Changed to project directory"
    else
        echo -e "\n${RED}Failed to enter project directory${NC}"
        exit 1
    fi
}

checkout_branch() {
    print_step "3" "6" "Switching to branch '$SELECTED_BRANCH'..."
    
    if git checkout "$SELECTED_BRANCH" >/dev/null 2>&1; then
        print_success "Switched to branch '${BOLD}$SELECTED_BRANCH${NC}'"
    else
        echo -e "\n${RED}Failed to checkout branch${NC}"
        exit 1
    fi
}

cleanup_files() {
    print_step "4" "6" "Cleaning project files..."
    
    local count=0
    
    for folder in "${CLEANUP_FOLDERS[@]}"; do
        [ -d "$folder" ] && rm -rf "$folder" && ((count++))
    done
    
    for file in "${CLEANUP_FILES[@]}"; do
        [ -f "$file" ] && rm -f "$file" && ((count++))
    done
    
    print_success "Removed ${BOLD}$count${NC} file(s)/folder(s)"
}

setup_environment() {
    print_step "5" "6" "Setting up environment..."
    
    if [ -f ".env.example" ]; then
        cp ".env.example" ".env"
        print_success "Created .env file"
    fi
    
    if php artisan key:generate >/dev/null 2>&1; then
        print_success "Generated application key"
    fi
}

install_dependencies() {
    if [ "$INSTALL_COMPOSER" = true ]; then
        print_step "6a" "6" "Installing Composer dependencies..."
        
        if composer install --no-interaction >/dev/null 2>&1; then
            print_success "Composer dependencies installed"
        else
            echo -e "\n${RED}Failed to install Composer dependencies${NC}"
            exit 1
        fi
    fi
    
    if [ "$INSTALL_NODE" = true ]; then
        print_step "6b" "6" "Installing Node dependencies ($SELECTED_RUNTIME)..."
        
        local cmd="$SELECTED_RUNTIME install"
        if $cmd >/dev/null 2>&1; then
            print_success "Node dependencies installed"
        else
            echo -e "\n${RED}Failed to install Node dependencies${NC}"
            exit 1
        fi
    fi
}

print_completion() {
    echo ""
    print_section "Installation Complete"
    echo ""
    echo -e "  ${GREEN}✔${NC} ${GREEN}Installation completed successfully!${NC}"
    echo ""
    echo -e "  ${GRAY}Project:${NC}  ${BOLD}$PROJECT_NAME${NC}"
    echo -e "  ${GRAY}Branch:${NC}   ${BOLD}$SELECTED_BRANCH${NC}"
    echo -e "  ${GRAY}Runtime:${NC}  ${BOLD}$SELECTED_RUNTIME${NC}"
    
    local deps="none"
    [ "$INSTALL_COMPOSER" = true ] && [ "$INSTALL_NODE" = true ] && deps="composer, node"
    [ "$INSTALL_COMPOSER" = true ] && [ "$INSTALL_NODE" = false ] && deps="composer"
    [ "$INSTALL_COMPOSER" = false ] && [ "$INSTALL_NODE" = true ] && deps="node"
    echo -e "  ${GRAY}Dependencies:${NC} ${BOLD}$deps${NC}"
    echo ""
    
    if [ "$INSTALL_COMPOSER" = false ] || [ "$INSTALL_NODE" = false ]; then
        echo -e "  ${YELLOW}⚠${NC} ${YELLOW}Some dependencies not installed automatically${NC}"
        [ "$INSTALL_COMPOSER" = false ] && echo -e "     ${GRAY}• composer install${NC}"
        [ "$INSTALL_NODE" = false ] && echo -e "     ${GRAY}• $SELECTED_RUNTIME install${NC}"
        echo ""
    fi
    
    echo -e "  ${GRAY}Next steps:${NC}"
    echo -e "     ${CYAN}cd $PROJECT_NAME${NC}"
    echo -e "     ${CYAN}php artisan serve${NC}"
    echo ""
    echo -e "  ${CYAN}Happy coding!${NC}"
    echo ""
    
    INSTALLATION_COMPLETED="true"
}

# ==============================================================================
# CLI PARSING
# ==============================================================================

show_help() {
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}${CYAN}   Better Laravel React Installer${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${BOLD}USAGE${NC}"
    echo -e "  better-laravel new [options]"
    echo ""
    echo -e "${BOLD}RUNTIME OPTIONS${NC}"
    echo -e "  --npm             Use npm (default)"
    echo -e "  --pnpm            Use pnpm"
    echo -e "  --yarn            Use yarn"
    echo -e "  --bun             Use bun"
    echo ""
    echo -e "${BOLD}INSTALL OPTIONS${NC}"
    echo -e "  --install-all     Install both Composer and Node (default)"
    echo -e "  --install-composer  Install only Composer dependencies"
    echo -e "  --install-node    Install only Node dependencies"
    echo -e "  --no-install      Skip dependency installation"
    echo ""
    echo -e "${BOLD}GENERAL${NC}"
    echo -e "  --help, -h        Show this help message"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo -e "  ${GRAY}better-laravel new${NC}"
    echo -e "  ${GRAY}better-laravel new --bun${NC}"
    echo -e "  ${GRAY}better-laravel new --pnpm --install-node${NC}"
    echo -e "  ${GRAY}better-laravel new --no-install${NC}"
    echo ""
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --npm) SELECTED_RUNTIME="npm"; CLI_MODE=true; shift ;;
            --pnpm) SELECTED_RUNTIME="pnpm"; CLI_MODE=true; shift ;;
            --yarn) SELECTED_RUNTIME="yarn"; CLI_MODE=true; shift ;;
            --bun) SELECTED_RUNTIME="bun"; CLI_MODE=true; shift ;;
            --install-all) INSTALL_COMPOSER=true; INSTALL_NODE=true; CLI_MODE=true; shift ;;
            --install-composer) INSTALL_COMPOSER=true; INSTALL_NODE=false; CLI_MODE=true; shift ;;
            --install-node) INSTALL_COMPOSER=false; INSTALL_NODE=true; CLI_MODE=true; shift ;;
            --no-install) INSTALL_COMPOSER=false; INSTALL_NODE=false; CLI_MODE=true; shift ;;
            --help|-h) show_help; exit 0 ;;
            *) echo -e "${RED}Unknown option: $1${NC}"; show_help; exit 1 ;;
        esac
    done
}

run_cli_mode() {
    print_section "Project Configuration"
    
    # Get project name
    while true; do
        echo ""
        echo -ne "  ${CYAN}Enter project name${NC}: "
        read -r PROJECT_NAME
        
        if validate_project_name "$PROJECT_NAME"; then
            print_success "Project name: ${BOLD}$PROJECT_NAME${NC}"
            break
        else
            print_error "Invalid project name"
        fi
    done
    
    # Get branch
    get_branch
    
    # Confirm
    echo ""
    print_success "Runtime: ${BOLD}${SELECTED_RUNTIME:-$DEFAULT_RUNTIME}${NC}"
    
    local install_desc="Composer + Node"
    [ "$INSTALL_COMPOSER" = true ] && [ "$INSTALL_NODE" = false ] && install_desc="Composer only"
    [ "$INSTALL_COMPOSER" = false ] && [ "$INSTALL_NODE" = true ] && install_desc="Node only"
    [ "$INSTALL_COMPOSER" = false ] && [ "$INSTALL_NODE" = false ] && install_desc="None"
    print_success "Installing: ${BOLD}$install_desc${NC}"
    
    echo ""
    echo -ne "  ${CYAN}Proceed?${NC} [y/N]: "
    read -r confirm
    
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo ""
        print_warning "Installation cancelled"
        echo ""
        exit 0
    fi
}

run_interactive() {
    get_project_name
    get_branch
    get_runtime
    get_auto_install
    confirm_installation
}

# ==============================================================================
# MAIN
# ==============================================================================

main() {
    local cmd="${1:-}"
    shift || true
    
    case "$cmd" in
        new)
            print_banner
            
            # Parse CLI arguments
            [ $# -gt 0 ] && parse_args "$@"
            
            # Set defaults for CLI mode
            if [ "$CLI_MODE" = true ]; then
                [ -z "$SELECTED_RUNTIME" ] && SELECTED_RUNTIME="$DEFAULT_RUNTIME"
            else
                check_dependencies
            fi
            
            # Run workflow
            if [ "$CLI_MODE" = true ]; then
                run_cli_mode
            else
                run_interactive
            fi
            
            echo ""
            print_section "Installing"
            echo ""
            
            INSTALLATION_STARTED="true"
            
            clone_repository
            enter_project_directory
            checkout_branch
            cleanup_files
            setup_environment
            install_dependencies
            
            print_completion
            ;;
        help|--help|-h|"")
            show_help
            ;;
        *)
            echo -e "${RED}Unknown command: $cmd${NC}"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
